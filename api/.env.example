APP_ENV=development
API_PREFIX=/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:15432/rag_learning
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ORIGINS_RAW=http://localhost:3000,http://127.0.0.1:3000
AUTH_MODE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=data/uploads
SUPABASE_STORAGE_BUCKET=documents
MAX_UPLOAD_SIZE_MB=20
ALLOWED_DATASET_EXTENSIONS_RAW=xlsx,xls,csv
ALLOWED_KNOWLEDGE_EXTENSIONS_RAW=pdf,docx,txt,md
AUTO_CREATE_SCHEMA=true
GEMINI_API_KEY=
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=5
RAG_MAX_DISTANCE=0.6
RAG_CANDIDATE_K=20
RAG_DISTANCE_MARGIN=0.08
RAG_MAX_CITATION_ASSETS=2
