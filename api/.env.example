APP_ENV=development
API_PREFIX=/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:15432/rag_learning
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ORIGINS_RAW=http://localhost:3000,http://127.0.0.1:3000
AUTH_MODE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=data/uploads
SUPABASE_STORAGE_BUCKET=documents
MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS_RAW=pdf,docx,txt,md
AUTO_CREATE_SCHEMA=true
