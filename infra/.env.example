# Docker Compose environment variables for local development
# Copy to infra/.env and customize as needed.

# PostgreSQL
POSTGRES_DB=rag_learning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_PASSWORD=

# API
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_learning
REDIS_URL=redis://redis:6379/0
ALLOWED_UPLOAD_EXTENSIONS_RAW=pdf,docx,txt,md,xlsx,xls,csv
CORS_ORIGINS_RAW=http://localhost:3000,http://127.0.0.1:3000

# RAG Configuration
RAG_TOP_K=5
RAG_MAX_DISTANCE=0.6
GEMINI_API_KEY=

# Supabase (optional; use your own project values)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=documents

# Web
NEXT_PUBLIC_API_BASE_URL=http://api:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
